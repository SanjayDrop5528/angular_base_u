{
  "name": "synapse",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build",
    "build:uat": "ng build --configuration=uat --source-map=false",
    "build:prod": "ng build --configuration=production --source-map=false",
    "pull": "git pull",
    "uat-deploy": "npm run pull && npm run build:uat && npm run uat-only-deploy",
    "uat-only-deploy": "wrangler pages deploy dist/synapse/browser/ --project-name=synapsemd --branch=main --commit-dirty=true",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@auth0/angular-jwt": "^5.2.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fullcalendar/angular": "^6.1.20",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/resource": "^6.1.20",
    "@fullcalendar/resource-timegrid": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@kolkov/angular-editor": "^3.0.5",
    "@meddv/ngx-pinch-zoom": "^20.0.0",
    "@ngx-formly/core": "^7.1.0",
    "@ngx-formly/material": "^7.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "ag-grid-angular": "^35.3.1",
    "ag-grid-community": "^35.3.1",
    "ag-grid-enterprise": "^35.3.1",
    "crypto-js": "^4.2.0",
    "firebase": "^12.14.0",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "ngx-colors": "^3.6.0",
    "ngx-image-zoom": "^3.0.0",
    "ngx-pinch-zoom": "^2.6.2",
    "pako": "^2.1.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.3.0",
    "uuid": "^14.0.0",
    "zone.js": "^0.16.2"
